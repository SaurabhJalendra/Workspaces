# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Logs
*.log
logs/

# Editors
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Node
node_modules/
npm-debug.log*

# Secrets / local overrides
.env
.env.local
*.key
*.pem

# Claude local-only settings (shared team settings live in settings.json)
.claude/settings.local.json

# === Project repos (each is its own git repo — meta-repo ignores them) ===
# This .gitignore lives at D:/Git Repos/. The meta-repo tracks only:
#   .claude/, CLAUDE.md, saurabh-pc.code-workspace, saurabh-laptop.code-workspace, scripts/
# Every other top-level folder here is a separate git repo (its own .git/), ignored by this meta-repo.

# Ignore all TOP-LEVEL folders only (leading / anchors to repo root)
# Nested folders like .claude/skills/ are NOT affected by this pattern.
/*/

# Re-include workspace-managed top-level folders
!/.claude/
!/scripts/

# Worktrees (parallel Claude sessions)
worktrees/
