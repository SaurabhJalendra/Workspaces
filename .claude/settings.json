{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git rev-parse:*)",
      "Bash(git stash list)",
      "Bash(git config --get:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm list:*)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list)",
      "Bash(pip show:*)",
      "Bash(uv --version)",
      "Bash(which:*)",
      "Bash(where:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
