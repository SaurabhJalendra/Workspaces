{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Hardened settings.json optimized for AUTO MODE. Allow list = anything safe and routine. Deny list = irreversible, expensive, or destructive. The deny list is the safety floor — auto mode bypasses prompts for allowed commands but CANNOT bypass deny.",

  "permissions": {
    "allow": [
      "// === Git: read-only ===",
      "Bash(git status)", "Bash(git status:*)", "Bash(git diff:*)",
      "Bash(git log:*)", "Bash(git show:*)", "Bash(git branch:*)",
      "Bash(git remote -v)", "Bash(git remote get-url:*)",
      "Bash(git rev-parse:*)", "Bash(git stash list)",
      "Bash(git config --get:*)", "Bash(git config --list)",
      "Bash(git ls-files:*)", "Bash(git blame:*)",
      "Bash(git describe:*)", "Bash(git rev-list:*)",
      "Bash(git worktree list)",

      "// === Git: safe writes ===",
      "Bash(git add:*)", "Bash(git commit:*)", "Bash(git commit -m:*)",
      "Bash(git checkout:*)", "Bash(git switch:*)",
      "Bash(git pull)", "Bash(git pull:*)",
      "Bash(git push)", "Bash(git push origin:*)",
      "Bash(git fetch:*)", "Bash(git stash:*)",
      "Bash(git tag:*)", "Bash(git merge:*)", "Bash(git rebase:*)",
      "Bash(git restore:*)", "Bash(git worktree add:*)", "Bash(git worktree remove:*)",
      "Bash(git init)", "Bash(git clone:*)",

      "// === GitHub CLI ===",
      "Bash(gh:*)",

      "// === File system: read/inspect ===",
      "Bash(ls:*)", "Bash(pwd)", "Bash(cd:*)",
      "Bash(cat:*)", "Bash(head:*)", "Bash(tail:*)", "Bash(less:*)",
      "Bash(find:*)", "Bash(grep:*)", "Bash(rg:*)",
      "Bash(file:*)", "Bash(stat:*)", "Bash(du:*)", "Bash(df:*)",
      "Bash(which:*)", "Bash(where:*)", "Bash(type:*)",
      "Bash(echo:*)", "Bash(printf:*)", "Bash(env)", "Bash(date)",
      "Bash(hostname)", "Bash(uname:*)", "Bash(whoami)",

      "// === File system: safe writes ===",
      "Bash(mkdir:*)", "Bash(touch:*)", "Bash(cp:*)", "Bash(mv:*)",
      "Bash(chmod +x:*)", "Bash(ln -s:*)",

      "// === Node / npm / pnpm / yarn ===",
      "Bash(node:*)", "Bash(node --version)",
      "Bash(npm:*)", "Bash(npx:*)", "Bash(pnpm:*)", "Bash(yarn:*)",

      "// === Python / pip / uv / poetry ===",
      "Bash(python:*)", "Bash(python3:*)", "Bash(py:*)",
      "Bash(pip:*)", "Bash(pip3:*)", "Bash(uv:*)",
      "Bash(poetry:*)", "Bash(pipx:*)", "Bash(pyenv:*)",
      "Bash(pytest:*)", "Bash(ruff:*)", "Bash(black:*)", "Bash(mypy:*)",
      "Bash(bandit:*)", "Bash(pip-audit:*)", "Bash(pylint:*)", "Bash(flake8:*)",

      "// === Go ===",
      "Bash(go:*)", "Bash(gofmt:*)", "Bash(govulncheck:*)",
      "Bash(golangci-lint:*)", "Bash(gosec:*)",

      "// === Rust ===",
      "Bash(cargo:*)", "Bash(rustc:*)", "Bash(rustup:*)", "Bash(rustfmt:*)",

      "// === Java / Kotlin / Gradle / Maven ===",
      "Bash(java:*)", "Bash(javac:*)", "Bash(mvn:*)", "Bash(gradle:*)", "Bash(./gradlew:*)",

      "// === Ruby / Bundler ===",
      "Bash(ruby:*)", "Bash(bundle:*)", "Bash(rake:*)", "Bash(rubocop:*)",

      "// === Build tools ===",
      "Bash(make:*)", "Bash(cmake:*)", "Bash(bazel:*)", "Bash(buck:*)",

      "// === Testing / Linting / Security ===",
      "Bash(jest:*)", "Bash(vitest:*)", "Bash(playwright:*)", "Bash(cypress:*)",
      "Bash(eslint:*)", "Bash(prettier:*)", "Bash(tsc:*)",
      "Bash(semgrep:*)", "Bash(gitleaks:*)", "Bash(trufflehog:*)",
      "Bash(pre-commit:*)",

      "// === Docker (read-only + dev local) ===",
      "Bash(docker ps:*)", "Bash(docker images:*)", "Bash(docker inspect:*)",
      "Bash(docker logs:*)", "Bash(docker version)", "Bash(docker info)",
      "Bash(docker compose ps:*)", "Bash(docker compose logs:*)",

      "// === Network: localhost only ===",
      "Bash(curl http://localhost:*)", "Bash(curl http://127.0.0.1:*)",
      "Bash(wget http://localhost:*)",

      "// === Editors / dev servers (read-info) ===",
      "Bash(code:*)", "Bash(vim:*)", "Bash(nano:*)",

      "// === Claude Code itself ===",
      "Bash(claude:*)", "Bash(claude plugin:*)", "Bash(claude mcp:*)",

      "// === Other safe ===",
      "Bash(jq:*)", "Bash(yq:*)", "Bash(xargs:*)",
      "Bash(sed:*)", "Bash(awk:*)", "Bash(tr:*)", "Bash(sort:*)", "Bash(uniq:*)",
      "Bash(wc:*)", "Bash(diff:*)", "Bash(patch:*)",
      "Bash(tar:*)", "Bash(unzip:*)", "Bash(gzip:*)",
      "Bash(true)", "Bash(false)",

      "Read(*)", "Glob(*)", "Grep(*)",
      "Edit(*)", "Write(*)", "NotebookEdit(*)",
      "Agent(*)", "Skill(*)",
      "WebSearch(*)", "WebFetch(*)",
      "TaskCreate(*)", "TaskUpdate(*)", "TaskList(*)", "TaskGet(*)",
      "mcp__claude-in-chrome__*"
    ],

    "deny": [
      "// === Irrecoverable file ops ===",
      "Bash(rm -rf /:*)", "Bash(rm -rf ~:*)", "Bash(rm -rf ~/:*)",
      "Bash(rm -rf /*:*)", "Bash(rm -fr /:*)", "Bash(rm -fr ~:*)",
      "Bash(rm -rf .git:*)", "Bash(rm -rf .git/*)",
      "Bash(rm -rf node_modules:*)",

      "// === Irrecoverable git ops ===",
      "Bash(git push --force)", "Bash(git push --force:*)",
      "Bash(git push -f)", "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard)", "Bash(git reset --hard:*)",
      "Bash(git clean -fd)", "Bash(git clean -fdx:*)",
      "Bash(git checkout --:*)", "Bash(git restore --staged --worktree:*)",
      "Bash(git branch -D:*)",
      "Bash(git push origin :*)",
      "Bash(git filter-branch:*)", "Bash(git filter-repo:*)",

      "// === Bypass commit hooks (NEVER) ===",
      "Bash(git commit --no-verify:*)", "Bash(git commit -n:*)",
      "Bash(git commit --no-gpg-sign:*)",

      "// === Privileged ops ===",
      "Bash(sudo:*)", "Bash(su:*)", "Bash(doas:*)",
      "Bash(chmod 777:*)", "Bash(chmod -R 777:*)",
      "Bash(chown:*)", "Bash(chown -R:*)",

      "// === Network curl-pipe-shell (supply chain) ===",
      "Bash(curl * | sh:*)", "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)", "Bash(wget * | bash:*)",
      "Bash(curl -fsSL * | sh:*)", "Bash(curl -fsSL * | bash:*)",

      "// === Dangerous shell ===",
      "Bash(eval:*)", "Bash(exec:*)",
      "Bash(:(){ :|:& };:*)",
      "Bash(dd if=:*)", "Bash(mkfs:*)", "Bash(fdisk:*)",
      "Bash(> /dev/sda:*)", "Bash(> /dev/null:*)",

      "// === Cloud CLIs (could spend money / affect prod) ===",
      "Bash(aws s3 rm:*)", "Bash(aws s3 sync --delete:*)",
      "Bash(aws ec2 terminate-instances:*)",
      "Bash(gcloud compute instances delete:*)",
      "Bash(az vm delete:*)", "Bash(az group delete:*)",
      "Bash(terraform destroy:*)", "Bash(terraform apply -auto-approve:*)",
      "Bash(kubectl delete:*)",

      "// === Package managers: destructive ===",
      "Bash(npm uninstall:*)", "Bash(pnpm remove:*)",
      "Bash(pip uninstall -y:*)",
      "Bash(cargo uninstall:*)",

      "// === Process kills: indiscriminate ===",
      "Bash(killall:*)", "Bash(pkill:*)",
      "Bash(kill -9 -1)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "(test -f \"$CLAUDE_FILE_PATH\" && (file=\"$CLAUDE_FILE_PATH\"; case \"$file\" in *.py) ruff format --silent \"$file\" 2>/dev/null || black -q \"$file\" 2>/dev/null ;; *.ts|*.tsx|*.js|*.jsx|*.json|*.md|*.yml|*.yaml) npx --silent prettier --write \"$file\" 2>/dev/null ;; *.go) gofmt -w \"$file\" 2>/dev/null ;; *.rs) rustfmt \"$file\" 2>/dev/null ;; esac)) || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(rm -rf|chmod 777|--no-verify|push --force|push -f|reset --hard|git clean -fd|sudo|curl [^|]+\\| ?sh|wget [^|]+\\| ?sh|filter-branch|filter-repo|terraform destroy|kubectl delete|aws s3 rm|aws s3 sync --delete)' && (echo '🛑 BLOCKED: dangerous command pattern detected' >&2; exit 1) || exit 0"
          }
        ]
      }
    ]
  }
}
